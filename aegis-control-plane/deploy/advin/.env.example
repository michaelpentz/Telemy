# Docker Compose runtime
POSTGRES_DB=aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=replace-with-strong-password

# Aegis API and jobs runtime
AEGIS_DATABASE_URL=postgres://aegis:replace-with-strong-password@postgres:5432/aegis?sslmode=disable
AEGIS_LISTEN_ADDR=:8080
AEGIS_JWT_SECRET=replace-with-long-random-secret
AEGIS_RELAY_SHARED_KEY=replace-with-long-random-secret
AEGIS_PLUGIN_LOGIN_COMPLETE_KEY=replace-with-long-random-secret
AEGIS_DEFAULT_REGION=us-east-1
AEGIS_SUPPORTED_REGIONS=us-east-1,eu-west-1
AEGIS_RELAY_PROVIDER=aws
AEGIS_AWS_AMI_MAP=us-east-1=ami-xxxxxxxxxxxxxxxxx,eu-west-1=ami-yyyyyyyyyyyyyyyyy
AEGIS_AWS_INSTANCE_TYPE=t4g.small
AEGIS_AWS_SUBNET_ID=subnet-xxxxxxxxxxxxxxxxx
AEGIS_AWS_SECURITY_GROUP_IDS=sg-xxxxxxxxxxxxxxxxx
AEGIS_AWS_KEY_NAME=your-ec2-key-name
AEGIS_AUTH_ACCESS_TOKEN_MINUTES=15
AEGIS_AUTH_REFRESH_TOKEN_DAYS=30
AEGIS_AUTH_PUBLIC_BASE_URL=https://telemyapp.com
AEGIS_PLUGIN_LOGIN_ATTEMPT_MINUTES=10
AEGIS_PLUGIN_LOGIN_POLL_INTERVAL_SECONDS=3
CLOUDFLARE_RELAY_DOMAIN=relay.telemyapp.com
CLOUDFLARE_ZONE_ID=replace-with-cloudflare-zone-id
CLOUDFLARE_DNS_TOKEN=replace-with-cloudflare-api-token
